name: daily-update

on:
  schedule:
    - cron: '0 21 * * *'   # 21:00 UTC daily ≈ 06:00 KST next morning
    - cron: '0 21 1 * *'   # 1st of month — also runs the slow-trend stats job
  workflow_dispatch: {}     # lets you run it manually from the Actions tab

permissions:
  contents: write
  pages: write
  id-token: write

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Check filter model health (records status + retirement)
        env:
          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}
          GEMINI_MODEL: gemini-2.5-flash
        run: python scripts/check_model.py

      - name: Layer 1 — news + free hybrid filter (keyword → Gemini → fallback)
        env:
          NEWS_API_KEY: ${{ secrets.NEWS_API_KEY }}
          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}
          GEMINI_MODEL: gemini-2.5-flash
        run: python scripts/collect.py

      - name: Layer 3 — first-party feeds (daily, free keyword filter)
        run: python scripts/collect_firstparty.py

      - name: Competitor trend — Wikipedia pageviews (free, no key)
        run: python scripts/collect_wiki.py

      - name: Layer 2 — slow-trend stats (1st of month only)
        if: ${{ startsWith(github.event.schedule, '0 21 1 ') || github.event_name == 'workflow_dispatch' }}
        run: python scripts/collect_stats.py

      - name: Rebuild dashboard
        run: python scripts/build.py

      - name: Commit updated data + page
        run: |
          git config user.name  "github-actions"
          git config user.email "actions@github.com"
          git add data/events.json data/feed_state.json data/model_status.json data/wiki_views.json index.html
          git commit -m "daily update $(date -u +%F)" || echo "no changes"
          git push

      - name: Upload Pages artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: .

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - id: deployment
        uses: actions/deploy-pages@v4
